{
    "name": "Existing Dockerfile",
    "build": {
        "dockerfile": "../dev.Dockerfile",
        "context": ".."
    },
    "runArgs": [
        "--network=host"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-azuretools.vscode-docker",
                "ms-python.python",
                "ms-python.pylint",
                "github.copilot",
                "anthropic.claude-code",
                "google.geminicodeassist",
                "ms-python.isort",
                "ms-python.black-formatter",
                "redhat.vscode-yaml"
            ],
            "settings": {
                "python.defaultInterpreterPath": "opt/venv/bin/python"
            }
        }
    }
}